# Backend environment configuration
# Copy to .env for local use. On Render, set these values in the service environment.

NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:4200
CORS_ALLOWED_ORIGINS=http://localhost:4200

# MySQL / Aiven
DB_HOST=localhost
DB_PORT=3306
DB_NAME=jdf_veterans_affairs_portal
DB_USER=root
DB_PASSWORD=
DB_CONNECTION_LIMIT=10
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

# Authentication
JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
JWT_REFRESH_EXPIRES_IN=7d
SESSION_SECRET=replace-with-a-long-random-session-secret
MAIN_ADMIN_BOOTSTRAP_KEY=replace-with-a-one-time-bootstrap-key

# Sensitive data protection
LOOKUP_HASH_PEPPER=replace-with-a-long-random-pepper
DATA_ENCRYPTION_KEY=replace-with-32-byte-base64-or-64-character-hex-key
DATA_ENCRYPTION_KEY_VERSION=1

# Optional one-time database seed for the highest admin authority.
# Use after importing database/jdf_portal_schema.sql.
SEED_MAIN_ADMIN_FULL_NAME=Marlon Beckford
SEED_MAIN_ADMIN_EMAIL=main.admin@example.gov.jm
SEED_MAIN_ADMIN_PASSWORD=ChangeThisStrongPassword!234
SEED_MAIN_ADMIN_RANK=Col
SEED_MAIN_ADMIN_REGIMENTAL_NUMBER=54321
SEED_MAIN_ADMIN_FORCE=false

# Uploads
UPLOAD_DIR=uploads
PRIVATE_UPLOAD_DIR=uploads/private
IDENTITY_UPLOAD_DIR=uploads/identity
REQUEST_UPLOAD_DIR=uploads/requests
PROFILE_UPLOAD_DIR=uploads/profiles
GALLERY_UPLOAD_DIR=uploads/gallery
MAX_UPLOAD_SIZE_MB=10

# Staff and security controls
ALLOW_STAFF_SELF_SIGNUP=true
REQUIRE_IDENTITY_VERIFICATION_FOR_ISSUANCE=true
